<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ProfilePageController">
   <children>

      <Label fx:id="lblWelcome" layoutX="200.0" layoutY="40.0" style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Welcome" />

      <!-- Optional subtitle -->
      <Label layoutX="260.0" layoutY="70.0" style="-fx-font-size: 14px;" text="Profile" />

      <!-- Profile info -->
      <GridPane hgap="15" layoutX="140.0" layoutY="100.0" vgap="12">

         <children>
            <Label text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <Label fx:id="lblName" text="-" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <Label fx:id="lblEmail" text="-" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label text="Payment:" GridPane.rowIndex="3" />
            <Label fx:id="lblPayment" text="-" GridPane.columnIndex="1" GridPane.rowIndex="3" />

            <Label text="Inbox:" GridPane.rowIndex="4" />
            <Label fx:id="lblInbox" text="You have 0 new messages" GridPane.columnIndex="1" GridPane.rowIndex="4" />

            <Label text="Purchase history:" GridPane.rowIndex="5" />
            <Label fx:id="lblHistory" text="(coming soon)" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="5" />
            <Label  text="Status:" GridPane.rowIndex="2" />
            <Label fx:id="lbStatus" text="-" GridPane.columnIndex="1" GridPane.rowIndex="2" />
         </children>
         <columnConstraints>
            <ColumnConstraints />
            <ColumnConstraints />
         </columnConstraints>
         <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
         </rowConstraints>

      </GridPane>

   </children>
</AnchorPane>
